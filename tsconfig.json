{
  "extends": "./temp/tsconfig.cocos.json",
  "compilerOptions": {
    "strict": false,
    "module": "commonjs",
    "lib": [
      "dom",
      "es6",
      "es5",
      "es2015.promise",
      "es2015",
      "es2017"
    ],
    "target": "es5",
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "outDir": "temp/vscode-dist",
    "forceConsistentCasingInFileNames": true,
    "downlevelIteration": true,
    // "paths": {
    //   "db://xianqu-utils/*": [
    //     "./extensions/xianqu-utils/assets/*"
    //   ],
    //   "db://xr-plugin/*": [
    //     "./extensions/xr-plugin/assets/*"
    //   ],
    //   "db://assets/*": [
    //     "./assets/*"
    //   ],
    // }
  },
  "exclude": [
    "node_modules",
    "library",
    "local",
    "temp",
    "build",
    "settings",
    "**/*.js"
  ],
  "include": [
    "./assets",
    "./dts/creator.d.ts",
    "./dts/global.d.ts",
    "./dts/index.d.ts",
    "./dts/tdanalytics.cc.d.ts",
    "./dts/HSDK.d.ts",
    "./dts/lz4.d.ts",
    "./dts/moment.d.ts",
  ]
}